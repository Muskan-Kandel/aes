    "dataset = Dataset.from_pandas(df_master[[\"text\"]])\n",
    "\n",
    "def tokenize_function(example):\n",
    "  tokens = tokenizer(\n",
    "      example[\"text\"],\n",
    "      truncation = True,\n",
    "      padding = \"max_length\",\n",
    "      max_length = 512\n",
    "  )\n",
    "\n",
    "  tokens[\"labels\"] = tokens[\"input_ids\"].copy()\n",
    "  return tokens\n",
    "\n",
    "tokenized_dataset = dataset.map(tokenize_function)"
   ]
